{
  "info": {
    "_postman_id": "b4f593f8-3f82-4f2a-9ff3-3f8d1ea57911",
    "name": "Job Portal - Application + Notification Flow",
    "description": "Feature test flow for applications, status updates, notifications, and mark-as-read.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Candidate Apply (POST /applications)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{candidateToken}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"jobId\": \"{{jobId}}\",\n  \"coverLetter\": \"I am excited to apply for this role.\",\n  \"resumeUrl\": \"{{resumeUrl}}\",\n  \"expectedSalary\": 50000\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/applications",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "applications"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response success is true', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.success).to.eql(true);",
              "});",
              "",
              "pm.test('Application status is Applied', function () {",
              "  const body = pm.response.json();",
              "  const status = String(body?.data?.status || '').toLowerCase();",
              "  pm.expect(status).to.eql('applied');",
              "});",
              "",
              "pm.test('Store applicationId from response', function () {",
              "  const body = pm.response.json();",
              "  const id = body?.data?._id || body?.data?.id;",
              "  pm.expect(id, 'application id missing in response').to.be.ok;",
              "  pm.collectionVariables.set('applicationId', String(id));",
              "});"
            ]
          }
        }
      ]
    },
