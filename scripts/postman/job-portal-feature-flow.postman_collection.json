    {
      "name": "06 - Recruiter Notifications (GET /notifications)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{recruiterToken}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/notifications",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "notifications"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Recruiter notifications fetched successfully', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "",
              "pm.test('Contains application submission notification', function () {",
              "  const body = pm.response.json();",
              "  const list = body?.data?.notifications || body?.data || body?.notifications || [];",
              "  pm.expect(Array.isArray(list)).to.eql(true);",
              "  const found = list.some(function (n) {",
              "    const text = `${n?.title || ''} ${n?.message || ''}`.toLowerCase();",
              "    return text.includes('apply') || text.includes('application') || text.includes('submitted');",
              "  });",
              "  pm.expect(found).to.eql(true);",
              "});",
              "",
              "pm.test('Store recruiterNotificationId for read check', function () {",
              "  const body = pm.response.json();",
              "  const list = body?.data?.notifications || body?.data || body?.notifications || [];",
              "  const first = Array.isArray(list) ? list[0] : null;",
              "  if (first && (first._id || first.id)) {",
              "    pm.collectionVariables.set('notificationId', String(first._id || first.id));",
              "  }",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "07 - Candidate Notifications (GET /notifications)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{candidateToken}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/notifications",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "notifications"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Candidate notifications fetched successfully', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "",
              "pm.test('Contains status update notification', function () {",
              "  const body = pm.response.json();",
              "  const list = body?.data?.notifications || body?.data || body?.notifications || [];",
              "  pm.expect(Array.isArray(list)).to.eql(true);",
              "  const found = list.some(function (n) {",
              "    const text = `${n?.title || ''} ${n?.message || ''}`.toLowerCase();",
              "    return text.includes('reviewed') || text.includes('rejected') || text.includes('accepted') || text.includes('status');",
              "  });",
              "  pm.expect(found).to.eql(true);",
              "});",
              "",
              "pm.test('Store candidate unread notificationId for read check', function () {",
              "  const body = pm.response.json();",
              "  const list = body?.data?.notifications || body?.data || body?.notifications || [];",
              "  const unread = Array.isArray(list) ? list.find(function (n) { return !n?.isRead; }) : null;",
              "  const target = unread || (Array.isArray(list) ? list[0] : null);",
              "  const id = target?._id || target?.id;",
              "  pm.expect(id, 'no candidate notification id found').to.be.ok;",
              "  pm.collectionVariables.set('notificationId', String(id));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "08 - Mark Notification As Read (PUT /notifications/:id/read)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{candidateToken}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/notifications/{{notificationId}}/read",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "notifications",
            "{{notificationId}}",
            "read"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Mark as read request succeeded', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "",
              "pm.test('isRead is true in response when present', function () {",
              "  const body = pm.response.json();",
              "  const data = body?.data || body;",
              "  if (typeof data === 'object' && data !== null && 'isRead' in data) {",
              "    pm.expect(data.isRead).to.eql(true);",
              "  } else {",
              "    pm.expect(true).to.eql(true);",
              "  }",
              "});"
            ]
          }
        }
      ]
    }
